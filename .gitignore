# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ───────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/

# ── Environment files (NEVER commit these — contains secrets) ─────────────────
.env
.env.local
.env.*.local
backend/.env

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Backend uploads (user data) ───────────────────────────────────────────────
backend/uploads/*.csv
backend/uploads/*.xlsx
backend/uploads/*.xls

# ── OS & IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Playwright / test artifacts ───────────────────────────────────────────────
.playwright-mcp/
test-results/
playwright-report/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tsbuildinfo
*.pem
coverage/
console-*.log
page-*.yml
page-*.png
launch.json
