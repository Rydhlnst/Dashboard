# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dashboard_monitoring
DB_USER=your_db_user
DB_PASS=your_db_password

# ── CORS: comma-separated list of allowed frontend origins ───────────────────
# For local dev:   http://localhost:3000
# For Vercel:      https://your-app.vercel.app
# For custom domain: https://dashboard.yourdomain.com
#
# IMPORTANT: Backend must be on HTTPS for cross-origin cookies to work
# (SameSite=None requires Secure flag, which requires HTTPS on both sides)
FRONTEND_URL=http://localhost:3000,https://your-app.vercel.app,https://dashboard.yourdomain.com
